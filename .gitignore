# Claude Code local state — keep skills/ subdirectory trackable since
# those are shared across the team, ignore everything else.
.claude/*
!.claude/skills/

# Evolution runtime artifacts — keep directories (via .gitkeep), ignore contents
evolution/state.json
evolution/logs/step_*.md
evolution/logs/step_*/
evolution/scores/v*.json
evolution/redirects/step_*.md

# Workspace runtime — test intermediates, deploy artifacts, build output
workspace/deploy/
workspace/runs/*/attempts/
workspace/runs/*/build_out/
workspace/runs/*/best/*/build_out/
workspace/runs/*/best/*/**/build_out/
workspace/runs/*/test/CppExtension/build/
workspace/runs/*/test/CppExtension/dist/
workspace/runs/*/test/CppExtension/*.egg-info/
workspace/runs/*/test/__pycache__/
**/__pycache__/

# S8 competition — ignore build artifacts and zip intermediates
workspace/competition/*/*/build_out/
workspace/competition/combined/*/build_out/
workspace/submissions/work/*_zip/
workspace/submissions/op/

# Python / build
__pycache__/
*.pyc
*.pyo
*.so
*.wheel
*.whl
build/
dist/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Local test sessions — test.md is session-scoped, reports are kept
test.md

# torch_npu runtime artifacts (generated on any NPU Python run)
fusion_result.json
kernel_meta/
